{
    "name": "embedded-test-runner",
    "version": "0.3.1",
    "description": "Test orchestration for embedded devices",
    "keywords": "testing, embedded, serial, crash-detection",
    "frameworks": [
        "arduino"
    ],
    "platforms": [
        "espressif32"
    ],
    "dependencies": [
        {
            "name": "embedded-bridge",
            "version": "https://github.com/m-mcgowan/embedded-bridge.git"
        }
    ],
    "build": {
        "srcDir": "src/etst",
        "srcFilter": [
            "-<*>"
        ],
        "includeDir": "include"
    }
}
